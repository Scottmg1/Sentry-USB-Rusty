#!/bin/bash -eu
# Thin forwarder around POST /api/notifications/send.
#
# The old implementation here spoke directly to every notifier (Discord,
# Slack, Pushover, …). The Rust server now owns that logic — this script
# just converts the positional-arg call contract into a JSON POST so
# existing callers (archiveloop, temperature_monitor, post-archive-process.sh,
# api handlers, etc.) keep working without modification.
#
# What stays on the bash side:
#   * The gate check (GET /api/notifications/settings/check) so we don't
#     run user-defined NOTIFICATION_COMMAND_* side effects when the
#     notification type is disabled.
#   * NOTIFICATION_COMMAND_START / NOTIFICATION_COMMAND_FINISH — user
#     shell snippets that need access to the *caller's* environment
#     (e.g. CURRENT_ARCHIVE_FILE set by archiveloop). Moving these into
#     the server would lose that env inheritance.
#
# Everything else — per-channel HTTP, mobile push, history logging — is
# handled by the Rust endpoint in a single server-side transaction.
#
# Call contract (unchanged from the previous bash implementation):
#   send-push-message <title> <message> [type] [notification_type]
#
# Reads env:
#   SENTRYUSB_PORT             — API port (default 80)
#   ARCHIVE_TOTAL_COUNT        — used for live_activity on archive_start
#   NOTIFICATION_COMMAND_ENABLED / _START / _FINISH — local shell hook

title="$1"
message="$2"
type="${3:-}"
notification_type="${4:-}"

LOG_FILE="${LOG_FILE:-/mutable/archiveloop.log}"
log() {
  echo "$(date): $*" >> "$LOG_FILE" 2>/dev/null || true
}

SENTRYUSB_PORT="${SENTRYUSB_PORT:-80}"
API_BASE="http://127.0.0.1:${SENTRYUSB_PORT}"

# --- Type gate (same semantics as the old bash script) ---------------------
# Skip entirely when the notification type is toggled off in user settings.
# Fail-open on API errors so transient server hiccups don't silently drop
# notifications (matches the defensive `|| true` approach in the old script).
if [ -n "$notification_type" ]; then
  gate_response=$(curl -sf --connect-timeout 2 --max-time 5 \
    "${API_BASE}/api/notifications/settings/check?type=${notification_type}" 2>/dev/null) || true
  if [ -n "$gate_response" ]; then
    gate_enabled=$(echo "$gate_response" | sed -n 's/.*"enabled" *: *\(true\|false\).*/\1/p')
    if [ "$gate_enabled" = "false" ]; then
      log "Notification type '$notification_type' is disabled by user settings. Skipping."
      exit 0
    fi
  fi
fi

# --- NOTIFICATION_COMMAND_* (runs locally with caller env) ---------------
# eval'd because users' config snippets may legitimately contain pipes,
# variable references, etc. Fire-and-forget via `&` so a slow / broken
# user command can't block the caller.
if [ "${NOTIFICATION_COMMAND_ENABLED:-false}" = "true" ]; then
  if [ -n "${NOTIFICATION_COMMAND_START:-}" ] && [ "$type" = "start" ]; then
    eval "$NOTIFICATION_COMMAND_START" &
  fi
  if [ -n "${NOTIFICATION_COMMAND_FINISH:-}" ] && [ "$type" = "finish" ]; then
    eval "$NOTIFICATION_COMMAND_FINISH" &
  fi
fi

# --- Forward everything else to the server -------------------------------
# Build the JSON with python3 so title / message can contain any printable
# character (quotes, backslashes, newlines from error messages, …)
# without breaking the request. python3 is already a hard dep because of
# the BLE daemon and the RTC service, so no new requirement.
payload=$(ARG_TITLE="$title" \
  ARG_MESSAGE="$message" \
  ARG_TYPE="$type" \
  ARG_NOTIFICATION_TYPE="$notification_type" \
  ARG_ARCHIVE_TOTAL_COUNT="${ARCHIVE_TOTAL_COUNT:-}" \
  python3 - <<'PYEOF'
import json, os
body = {
    "title":   os.environ.get("ARG_TITLE", ""),
    "message": os.environ.get("ARG_MESSAGE", ""),
}
t = os.environ.get("ARG_TYPE", "")
if t:
    body["type"] = t
nt = os.environ.get("ARG_NOTIFICATION_TYPE", "")
if nt:
    body["notification_type"] = nt
atc = os.environ.get("ARG_ARCHIVE_TOTAL_COUNT", "")
if atc.isdigit():
    body["archive_total_count"] = int(atc)
print(json.dumps(body))
PYEOF
)

# Log the message the user asked us to send, matching the old script's
# behavior of echoing to the log before any network IO.
log "$message"

# Best-effort POST. Keep bash's fail-soft stance: the API running the
# binary may be temporarily down (crash, update in progress); we log and
# move on rather than break the caller.
response=$(curl -s --connect-timeout 5 --max-time 30 -w "\n%{http_code}" \
  -X POST \
  -H "Content-Type: application/json" \
  -d "$payload" \
  "${API_BASE}/api/notifications/send" 2>/dev/null) || {
    log "ERROR: notifications/send — curl failed (exit code $?)"
    exit 0
  }

http_code=$(echo "$response" | tail -1)
body=$(echo "$response" | sed '$d')

if [ "$http_code" -ge 200 ] 2>/dev/null && [ "$http_code" -lt 300 ] 2>/dev/null; then
  # Log summary if present so the user can tell from /mutable/archiveloop.log
  # whether the notification went through.
  skipped=$(echo "$body" | sed -n 's/.*"skipped" *: *true.*/true/p')
  if [ "$skipped" = "true" ]; then
    log "Notifications skipped (type disabled by server)"
  else
    attempted=$(echo "$body" | sed -n 's/.*"attempted" *: *\([0-9]*\).*/\1/p')
    [ -n "$attempted" ] && log "Notifications attempted: $attempted"
  fi
else
  log "ERROR: notifications/send — HTTP $http_code — $body"
fi

exit 0
